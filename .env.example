# Copy to .env for `docker compose`. Values here are dev defaults — set strong
# secrets for any non-local deployment.

# ---- Database ----
POSTGRES_USER=mpc
POSTGRES_PASSWORD=mpc
POSTGRES_DB=mpc

# ---- API ----
JWT_SECRET=change-me-to-a-long-random-value
JWT_EXPIRES_IN=8h
# Enable the demo /auth/token endpoint. MUST be false in production.
ALLOW_DEV_LOGIN=true
CORS_ORIGINS=http://localhost:3000

# ---- OIDC / Azure AD (Entra ID) — leave blank to use local dev login ----
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=
OIDC_ROLES_CLAIM=roles

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
