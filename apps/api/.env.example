# ---- Database ----
DATABASE_URL="postgresql://mpc:mpc@localhost:5432/mpc?schema=public"

# ---- API ----
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed web origins (CORS)
CORS_ORIGINS="http://localhost:3000"

# ---- Auth ----
# Local/dev JWT signing secret (HS256). Used only when OIDC_ISSUER is empty.
JWT_SECRET="change-me-in-production-please-use-a-long-random-value"
JWT_EXPIRES_IN="8h"
# Set to "true" to allow POST /api/auth/token to mint dev tokens (NEVER in prod).
ALLOW_DEV_LOGIN=true

# ---- OIDC / Azure AD (Entra ID) — production SSO ----
# When OIDC_ISSUER is set, JWTs are validated against the issuer's JWKS (RS256).
OIDC_ISSUER=""
OIDC_AUDIENCE=""
OIDC_JWKS_URI=""
# Claim that carries the application role(s); e.g. "roles" or "groups".
OIDC_ROLES_CLAIM="roles"
